<div class="container"
     id="sso_warnings_viewlet"
     tal:condition="view/show_alert"
>
  <div class="alert alert-warning"
       tal:define="
         portal context/portal_url/getPortalObject;
       "
  >
    <tal:warning condition="view/show_warning">
      <strong>Login Warning</strong>
      <tal:unknown condition="python:view.status() == 'unknown'">
        <p>There is not an active account with your
          <b tal:content="view/login_info"></b>
           credentials on this site.
        </p>
        <p>
          If you have linked your account with a different service provider you may
          <a href="/Shibboleth.sso/PloneLogin?target=${portal/absolute_url}">login with that service
            provider</a>
           instead.
        </p>
      </tal:unknown>
    </tal:warning>

    <tal:inactive condition="view/is_inactive">
            Your account has been locked due to inactivity for security reasons.
      <form action="${view/reactivation_url}"
            method="POST"
      >
        <span tal:replace="structure context/@@authenticator/authenticator"></span>
        <button class="btn btn-primary">
                    Reactivate my account
        </button>
      </form>
    </tal:inactive>

    <tal:disabled condition="view/is_disabled">
            Your account has been disabled. Contact the
      <a href="${context/absolute_url}/contact-info">site administrator</a>
       to request reactivation.
    </tal:disabled>
  </div>
</div>
