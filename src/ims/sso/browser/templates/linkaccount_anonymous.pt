<html xmlns="http://www.w3.org/1999/xhtml"
      lang="en-US"
      metal:use-macro="here/main_template/macros/master"
      xml:lang="en-US"
      i18n:domain="ims.sso"
>
  <body>

    <metal:main fill-slot="main">

      <h1 class="documentFirstHeading"
          i18n:translate="heading_pwreset_invalid"
      >Error linking your account</h1>

      <div id="content-core">
        <p i18n:translate="message_linkaccount_invalid">
           You must log in to your identity provider before you can link your account to this site.
        </p>
      </div>

    </metal:main>

  </body>
</html>
