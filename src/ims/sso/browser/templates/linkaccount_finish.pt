<html xmlns="http://www.w3.org/1999/xhtml"
      lang="en-US"
      metal:use-macro="here/main_template/macros/master"
      xml:lang="en-US"
      i18n:domain="ims.sso"
>
  <body>

    <div metal:fill-slot="main">
      <h1 i18n:translate="heading_linkaccount_success">Login Service Updated</h1>

      <p i18n:translate="message_linkaccount_success">
        Your portal account has been successfully linked with your Login Service account.
        <br />
        <a href="${context/portal_url}">Proceed to the home page.</a>
      </p>

    </div>

  </body>
</html>
