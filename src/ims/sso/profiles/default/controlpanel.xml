<?xml version="1.0" encoding="utf-8"?>
<object xmlns:i18n="http://xml.zope.org/namespaces/i18n"
        meta_type="Plone Control Panel Tool"
        name="portal_controlpanel"
        i18n:domain="ims.sso"
>
  <configlet action_id="ims-sso"
             appId="ims.sso"
             category="plone-users"
             condition_expr=""
             icon_expr="string:key"
             title="SSO Settings"
             url_expr="string:${portal_url}/@@sso-settings"
             visible="True"
             i18n:attributes="title"
  >
    <permission>ims.sso: basic settings</permission>
  </configlet>
  <configlet action_id="MemberFields"
             appId="MemberFields"
             category="plone-users"
             condition_expr=""
             icon_expr="string:card-list"
             title="Member Fields"
             url_expr="string:${portal_url}/@@member-fields"
             visible="True"
             i18n:attributes="title"
  >
    <permission>ims.sso: advanced settings</permission>
  </configlet>
  <configlet action_id="UsersGroupsSettings"
             appId="UsersGroupsSettings"
             category="plone-users"
             condition_expr=""
             icon_expr="string:toggles"
             title="User and Group Settings"
             url_expr="string:${portal_url}/@@usergroup-controlpanel"
             visible="True"
             i18n:attributes="title"
  >
    <permission>ims.sso: advanced settings</permission>
  </configlet>
</object>
